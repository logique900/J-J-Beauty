{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the system",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "phone": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "totalSpent": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Address": {
      "title": "Address",
      "description": "A user's saved address",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "name": { "type": "string" },
        "street": { "type": "string" },
        "city": { "type": "string" },
        "zip": { "type": "string" },
        "country": { "type": "string" },
        "phone": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["label", "name", "street", "city", "country", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "An item in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "brandId": { "type": "string" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "price": { "type": "number" },
        "comparePrice": { "type": "number" },
        "cost": { "type": "number" },
        "sku": { "type": "string" },
        "stock": { "type": "number" },
        "alertThreshold": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "active", "archived"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "price", "stock", "status", "createdAt", "updatedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "position": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "position", "status", "createdAt", "updatedAt"]
    },
    "Brand": {
      "title": "Brand",
      "description": "A product brand.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "website": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An ecommerce order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "refunded"] },
        "totalAmount": { "type": "number" },
        "payment": { "type": "string" },
        "shipping": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "address": { "type": "string" },
        "items": { "type": "array" },
        "newsletterOptIn": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerEmail", "status", "totalAmount", "createdAt", "updatedAt"]
    },
    "Passkey": {
      "title": "Passkey",
      "description": "A WebAuthn/Biometric credential",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "deviceName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "email", "deviceName", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A record of a unique visitor on a specific day",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "userId": { "type": "string" },
        "anonymousId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "createdAt"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A curated collection of products (e.g. New Arrivals)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["Actif", "Brouillon"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "image", "status", "createdAt", "updatedAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "contactEmail": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "currency": { "type": "string" },
        "socialLinks": { "type": "object" }
      }
    },
    "HeroSlide": {
      "title": "HeroSlide",
      "description": "A slide in the hero section carousel",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "cta": { "type": "string" },
        "position": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "image", "position", "status", "createdAt", "updatedAt"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "An email subscriber for newsletters",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile collection"
    },
    "/users/{userId}/addresses/{addressId}": {
      "schema": { "$ref": "#/entities/Address" },
      "description": "User's saved addresses"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Order records"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Catalog of products."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories."
    },
    "/brands/{brandId}": {
      "schema": { "$ref": "#/entities/Brand" },
      "description": "Product brands."
    },
    "/collections/{collectionId}": {
      "schema": { "$ref": "#/entities/Collection" },
      "description": "Product collections."
    },
    "/settings/{settingsId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global settings."
    },
    "/passkeys/{passkeyId}": {
      "schema": { "$ref": "#/entities/Passkey" },
      "description": "WebAuthn credentials mapping."
    },
    "/visits/{visitId}": {
      "schema": { "$ref": "#/entities/Visit" },
      "description": "Visitor analytics records"
    },
    "/hero-slides/{slideId}": {
      "schema": { "$ref": "#/entities/HeroSlide" },
      "description": "Hero section slides"
    },
    "/subscribers/{emailId}": {
      "schema": { "$ref": "#/entities/Subscriber" },
      "description": "Email subscribers for the newsletter"
    }
  }
}
